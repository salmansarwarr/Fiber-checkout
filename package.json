{
  "name": "fiber-checkout",
  "version": "0.1.0",
  "type": "module",
  "description": "React component suite for Fiber Network payments",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nervosnetwork/fiber.git",
    "directory": "fiber-checkout"
  },
  "author": "Nervos Network",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nervosnetwork/fiber/issues"
  },
  "homepage": "https://github.com/nervosnetwork/fiber/tree/main/fiber-checkout#readme",
  "keywords": [
    "fiber-network",
    "ckb",
    "nervos",
    "lightning-network",
    "payment-gateway",
    "react-component",
    "crypto-payments"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:testnet": "npx tsx scripts/test-testnet.ts",
    "test:node": "npx tsx scripts/test-node.ts",
    "coverage": "vitest run --coverage",
    "size": "npm run build && npx tsx scripts/check-bundle-size.ts",
    "verify": "npm run typecheck && npm run test && npm run build && npx tsx scripts/check-bundle-size.ts"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@nervosnetwork/fiber-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nervosnetwork/fiber-js": "^0.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/qrcode.react": "^3.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^24.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@nervosnetwork/fiber-js": "^0.7.0",
    "qrcode.react": "^4.2.0"
  }
}