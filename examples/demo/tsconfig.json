{
    "compilerOptions": {
      "target": "ESNext",
      "lib": ["ESNext", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "jsx": "react-jsx",
      "strict": true,
      "skipLibCheck": true,
      "esModuleInterop": true,
      "allowImportingTsExtensions": true,
      "noEmit": true,
      "ignoreDeprecations": "6.0",
      "baseUrl": ".",
      "paths": {
        "fiber-checkout": ["../../src/index.ts"]
      },
      "types": ["vite/client"]
    },
    "include": ["src"]
  }